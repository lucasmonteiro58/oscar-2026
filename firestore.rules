rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: each user can read/write only their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Votes: each user can read/write only their own vote
    match /votes/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    // Results: readable by all (for ranking), writable only via Admin (client-side password)
    // In production you'd use Firebase Admin or a backend to enforce admin writes
    match /results/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
